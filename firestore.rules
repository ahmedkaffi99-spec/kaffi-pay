rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Ordres dépôt — clients créent et lisent, admin met à jour
    match /depot_orders/{docId} {
      allow read: if true;
      allow create: if validOrder();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Ordres retrait — clients créent et lisent, admin met à jour
    match /retrait_orders/{docId} {
      allow read: if true;
      allow create: if validOrder();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Ancienne collection orders (rétrocompatibilité)
    match /orders/{docId} {
      allow read: if true;
      allow create: if validOrder();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Ordres traités (archivage admin)
    match /ordre_traite/{docId} {
      allow read, write: if isAdmin();
    }

    // Ordres confirmés (archivage admin)
    match /ordre_confirme/{docId} {
      allow read, write: if isAdmin();
    }

    // SMS Waafi — lecture publique, écriture Cloud Functions uniquement
    match /waafi_notifications/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Config (taux, agents) — lecture publique, écriture admin
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Compteur d'ordres — lecture/écriture publique (incrément séquentiel uniquement)
    match /counters/{docId} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasAll(['day', 'count'])
                   && request.resource.data.day is string
                   && request.resource.data.count is int
                   && request.resource.data.count >= 1
                   && request.resource.data.count <= 99999;
    }

    // Tout le reste — Cloud Functions uniquement (Admin SDK bypasse les règles)
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.resource.data.get('_ak', '') == 'kp2026_9f3aXmQ7';
    }

    function validOrder() {
      let d = request.resource.data;
      return d.keys().hasAll(['orderId', 'type', 'montant', 'status'])
          && d.status == 'En attente'
          && d.montant is number
          && d.montant >= 50
          && d.montant <= 500000
          && (d.type == 'Dépôt' || d.type == 'Retrait');
    }
  }
}
