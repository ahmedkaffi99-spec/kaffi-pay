rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Ordres — clients créent et lisent, admin met à jour
    match /orders/{docId} {
      allow read: if true;
      allow create: if validOrder();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // SMS Waafi — lecture admin, écriture Cloud Functions uniquement
    match /waafi_notifications/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Config (taux, agents) — lecture publique, écriture admin
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tout le reste — Cloud Functions uniquement (Admin SDK bypasse les règles)
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.resource.data.get('_ak', '') == 'kp2026_9f3aXmQ7';
    }

    function validOrder() {
      let d = request.resource.data;
      return d.keys().hasAll(['orderId', 'type', 'montant', 'status'])
          && d.status == 'En attente'
          && d.montant is number
          && d.montant >= 50
          && d.montant <= 500000
          && (d.type == 'Dépôt' || d.type == 'Retrait');
    }
  }
}
