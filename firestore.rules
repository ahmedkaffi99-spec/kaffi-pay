rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ORDERS ─────────────────────────────────────────────────────
    // Clients : créer (validé) + lire
    // Admin panel : lire tout + mettre à jour (clé admin requise)
    match /orders/{docId} {
      allow read: if true;
      allow create: if validOrder();
      allow update: if isAdminWrite();
      allow delete: if false;
    }

    // ── WAAFI NOTIFICATIONS ─────────────────────────────────────────
    // Admin panel lit et met à jour le statut (clé admin requise)
    // Cloud Functions créent (Admin SDK, hors règles)
    match /waafi_notifications/{docId} {
      allow read: if true;
      allow update: if isAdminWrite();
      allow create, delete: if false;
    }

    // ── CONFIG (agents, reserves) ───────────────────────────────────
    // Admin panel lit librement, écrit avec clé admin
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdminWrite();
    }

    // ── COLLECTIONS SENSIBLES — Cloud Functions uniquement ──────────
    // L'Admin SDK contourne ces règles → les fonctions fonctionnent normalement
    // Aucun accès direct depuis le navigateur

    match /ordre_traite/{docId} {
      allow read, write: if false;
    }
    match /support_sessions/{docId} {
      allow read, write: if false;
    }
    match /system_locks/{docId} {
      allow read, write: if false;
    }
    match /circuit_breakers/{docId} {
      allow read, write: if false;
    }
    match /audit_log/{docId} {
      allow read, write: if false;
    }
    match /rate_limits/{docId} {
      allow read, write: if false;
    }
    match /macro_jobs/{docId} {
      allow read, write: if false;
    }

    // ── TOUT LE RESTE : BLOQUÉ ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── CLÉ ADMIN ───────────────────────────────────────────────────
    // Clé stockée dans localStorage de l'admin uniquement (pas dans le code source)
    // L'admin doit exécuter une fois dans sa console :
    //   localStorage.setItem('kp_admin_key', 'kp2026_9f3aXmQ7')
    function isAdminWrite() {
      return request.resource.data.keys().hasAny(['_ak'])
          && request.resource.data._ak == 'kp2026_9f3aXmQ7';
    }

    // ── VALIDATION ORDRE ────────────────────────────────────────────
    function validOrder() {
      let d = request.resource.data;
      return d.keys().hasAll(['orderId', 'type', 'montant', 'status'])
          && d.status == 'En attente'
          && d.montant is number
          && d.montant >= 50
          && d.montant <= 500000
          && (d.type == 'Dépôt' || d.type == 'Retrait');
    }
  }
}
