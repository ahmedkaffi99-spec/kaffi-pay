rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // MacroDroid et clients écrivent sans authentification
    match /waafi_notifications/{doc} {
      allow write: if true;
      allow read: if request.auth != null;
    }

    // Clients soumettent des ordres et les lisent pour le suivi (sans auth)
    match /orders/{doc} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if request.auth != null;
    }

    // Tout le reste nécessite une authentification admin
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
